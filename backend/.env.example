# Generar con: openssl rand -hex 32
SECRET_KEY=change_this_with_openssl_rand_hex_32

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_8chars_min

DEBUG=false

# SQLite (desarrollo) o PostgreSQL (producción)
# Para PostgreSQL: postgresql://user:password@localhost:5432/uocra
DATABASE_URL=sqlite:///./uocra.db

# Pool settings (solo para PostgreSQL)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Orígenes permitidos (separados por coma, sin espacios)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# URL base para QR (se actualiza automáticamente con start.sh)
BASE_URL=

# Frontend URL para redirecciones
FRONTEND_URL=http://localhost:5174

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File upload settings
MAX_FILE_SIZE=16777216
UPLOAD_FOLDER=static/uploads
PHOTOS_FOLDER=static/photos
LOGOS_FOLDER=static/logos
